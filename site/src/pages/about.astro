---
import BaseLayout from '../layouts/BaseLayout.astro';
import ThreeBackground from '../components/ThreeBackground.astro';
import Navigation from '../components/Navigation.astro';

const base = import.meta.env.BASE_URL;
---

<BaseLayout title="About - ronsween" description="About me and my work">
  <Navigation />

  <main class="about-page">
    <div class="container">
      <h1 class="page-title">About Me</h1>

      <div class="content-grid">
        <section class="content-section intro-section">
          <h2>Hello, I'm ronsween</h2>
          <p>
            I am a thought follower with a passion for iRacing—though I'll admit, those 1.5-mile tracks still have my number.
          </p>
          <p>
            I consider my professional life just a long-term side quest until I hit the top rank on iRacing. Once I conquer that virtual tarmac, I’ll have no time for said side quests.
          </p>
        </section>

        <section class="content-section">
          <h2>What I Do</h2>
          <div class="what-i-do-grid">
            <div class="service-card">
              <div class="service-icon">
